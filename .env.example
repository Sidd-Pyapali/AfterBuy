# Root .env.example — template only. Not used at runtime.
# Backend secrets go in backend/.env
# Frontend public vars go in frontend/.env.local

# --- backend/.env ---

# OpenAI (backend only)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase (backend only - service role key)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_STORAGE_BUCKET=item-images

# SerpApi (backend only)
SERPAPI_API_KEY=your_serpapi_api_key_here

# --- frontend/.env.local ---

# Backend URL (public)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Supabase (public anon key only)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
